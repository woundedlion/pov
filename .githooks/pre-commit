#!/bin/sh
# Holosphere pre-commit hook — build and run the native unit tests, and abort
# the commit if anything fails.
#
# Enable for this checkout with:
#     git config core.hooksPath .githooks
# Bypass a single commit with:
#     git commit --no-verify
#
# Uses the CMake "tests" preset (Ninja + the auto-located Clang toolchain — the
# same path as build_tests.bat). Configure is cached and builds are incremental,
# so a typical commit only pays the changed-file rebuild plus the ~4s test run.
# Doc-only commits skip the suite entirely.

set -e

# Run only when C++/CMake/test sources are staged; skip doc-only commits.
CHANGED="$(git diff --cached --name-only --diff-filter=ACM)"
if ! printf '%s\n' "$CHANGED" | grep -qE '\.(h|hpp|cpp|cc|inl)$|(^|/)CMakeLists\.txt$|(^|/)CMakePresets\.json$|(^|/)cmake/'; then
  echo "[pre-commit] No C++/build changes staged — skipping unit tests."
  exit 0
fi

echo "[pre-commit] Building + running unit tests (cmake --preset tests)..."
if ! { cmake --preset tests && cmake --build --preset tests && ctest --preset tests --output-on-failure; }; then
  echo "[pre-commit] Unit tests FAILED — commit aborted."
  echo "[pre-commit] (fix the tests, or bypass once with: git commit --no-verify)"
  exit 1
fi

echo "[pre-commit] Unit tests passed."
exit 0
