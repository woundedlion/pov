#!/bin/sh
# Holosphere pre-commit hook — build and run the native unit tests, aborting the
# commit if anything fails.
#
# ON BY DEFAULT (opt-out). Configuring the `tests` CMake preset enables it
# automatically (core.hooksPath=.githooks; see CMakeLists.txt). To enable it by
# hand for a fresh clone:
#     git config core.hooksPath .githooks
#
# Opt OUT of a single commit:
#     HS_SKIP_TESTS=1 git commit ...        (or:  git commit --no-verify)
#
# Uses the CMake "tests" preset (Ninja + auto-located Clang). Configure is cached
# and builds are incremental, so a typical commit pays only the changed-file
# rebuild plus the ~4s test run. Doc-only commits skip the suite entirely.
#
# SCOPE: the "run or skip" decision keys on the STAGED paths (git diff --cached),
# but the build/test below compiles the WORKING TREE, not the index. For whole-
# file commits these coincide. With partial staging (git add -p) they can differ:
# the suite then validates unstaged content, so a split commit can pass here while
# its staged hunks alone do not compile. CI rebuilds from the committed tree and
# is the authoritative gate for that case; this hook is a fast local pre-filter.
#
# COVERAGE GAP (frame-cyclic paths): this hook runs the suite with the default
# HS_SMOKE_FRAMES (8 — see kDefaultFrames in tests/test_effects.h), which never
# reaches the long cyclic windows: effect morph cycles, particle/trail wraps,
# FIFO/slot expiry (Thrusters, RingShower), ShapeShifter's 48-frame cut, and
# arena compaction. CI sets HS_SMOKE_FRAMES=120 (.github/workflows/ci.yml) to
# exercise them on every push/PR, so a green pre-commit is NOT authoritative for
# those paths — a regression there fails only in CI, by design (the hook stays
# fast). To reproduce CI locally: HS_SMOKE_FRAMES=120 ctest --preset tests.

set -e

# Per-commit opt-out.
if [ -n "$HS_SKIP_TESTS" ]; then
  echo "[pre-commit] HS_SKIP_TESTS set — skipping unit tests."
  exit 0
fi

# Run only when C++/CMake/test sources are staged; skip doc-only commits.
# Include D (deletions) and R (renames): removing or renaming a C++/build file is
# exactly the change class most likely to break other checkouts, so it must run
# the suite too. (A renamed/deleted path still matches the extension grep below.)
# tests/ubsan-ignorelist.txt is included because it directly changes what the
# sanitizer build suppresses, so a local edit should re-run the suite. The
# justfile / .github/workflows/ci.yml / .githooks cases are intentionally left to
# CI (which rebuilds from the committed tree and is the authoritative gate).
CHANGED="$(git diff --cached --name-only --diff-filter=ACMRD)"

# Two gates key off the staged paths. NATIVE: the host unit suite (C++/CMake).
# TEENSY: the Teensy 4 size/layout gate, which any C++ change can move, plus the
# build/budget/ldscript files that drive the firmware image.
NATIVE=
TEENSY=
if printf '%s\n' "$CHANGED" | grep -qE '\.(h|hpp|cpp|cc|inl)$|(^|/)CMakeLists\.txt$|(^|/)CMakePresets\.json$|(^|/)cmake/|(^|/)tests/ubsan-ignorelist\.txt$'; then
  NATIVE=1
fi
if printf '%s\n' "$CHANGED" | grep -qE '\.(h|hpp|cpp|cc|inl|ino)$|(^|/)platformio\.ini$|(^|/)tools/teensy_[A-Za-z_]*\.py$|(^|/)tools/teensy_budgets\.json$|(^|/)tools/phantasm\.ld$'; then
  TEENSY=1
fi
if [ -z "$NATIVE" ] && [ -z "$TEENSY" ]; then
  echo "[pre-commit] No C++/build changes staged — skipping unit tests + Teensy gate."
  exit 0
fi

# Caveat: emscripten-only TUs (e.g. targets/wasm/wasm.cpp, guarded entirely by
# #ifdef __EMSCRIPTEN__) match the grep above and so trigger this hook, but they
# are NOT part of the native test target — none of their changed code is compiled
# here. An embind signature typo passes this gate and fails only in CI's wasm
# job. Catching it locally would require an `emcc` syntax pass (EMSDK-gated),
# deliberately omitted to keep the per-commit hook fast.
if [ -n "$NATIVE" ]; then
  echo "[pre-commit] Building + running unit tests (cmake --preset tests)..."
  if ! { cmake --preset tests && cmake --build --preset tests && ctest --preset tests --output-on-failure; }; then
    echo "[pre-commit] Unit tests FAILED — commit aborted."
    echo "[pre-commit] (fix the tests, or bypass once with: HS_SKIP_TESTS=1 git commit  /  --no-verify)"
    exit 1
  fi
  echo "[pre-commit] Unit tests passed."
fi

# ─── Teensy 4 size/layout gate (both shipping images) ───────────────────────
# Build both images and let the post-build extra_script
# (tools/teensy_gate_extra.py) enforce the per-region budgets in
# tools/teensy_budgets.json — a non-zero exit aborts the commit. Phantasm is the
# binding RAM1 image, but Holosphere has its own budget/layout, so both are
# gated here to match CI's teensy-size job exactly. Skipped if PlatformIO is
# absent (a contributor without the ARM toolchain still commits — CI catches it)
# or via HS_SKIP_TEENSY=1.
if [ -n "$TEENSY" ] && [ -z "$HS_SKIP_TEENSY" ]; then
  if command -v pio >/dev/null 2>&1; then
    echo "[pre-commit] Teensy size/layout gate (pio run -e holosphere -e phantasm)..."
    if ! pio run -e holosphere -e phantasm; then
      echo "[pre-commit] Teensy size/layout gate FAILED — commit aborted."
      echo "[pre-commit] (bypass once with: HS_SKIP_TEENSY=1 git commit  /  --no-verify)"
      exit 1
    fi
    echo "[pre-commit] Teensy gate passed."
  else
    echo "[pre-commit] PlatformIO (pio) not found — skipping Teensy gate (CI enforces it)."
  fi
fi

exit 0
