{
  // ==========================================================================
  // Teensy 4 firmware size + layout budgets — consumed by tools/teensy_gate.py
  // (docs/teensy_ci_gate_spec.md §8). JSONC: // and /* */ comments are stripped.
  //
  // CALIBRATED FROM REAL BUILDS: teensy@5.0.0 (Teensyduino 1.59.0 / arm-gcc
  // 11.3.1), PlatformIO 6.1.19, FastLED 3.4.0. Both shipping images pass.
  // Holosphere keeps the bench-parity -O3 configuration. Phantasm uses -Os,
  // newlib-nano, a flash-routing linker script, and the measured 330 KiB arena;
  // it uses 509,312 B of RAM1 with 14,976 B free for locals. Holosphere RAM2
  // is 518,272 B; Phantasm RAM2 is 519,552 B.
  //
  // Symbol names are the REAL linkage names from `readelf -s` (§7.4): the arena is
  // file-scope static, so it mangles to `_ZL18global_arena_block` (NOT the source
  // spelling). A renamed/missing layout symbol is a hard failure, never a silent
  // pass. Raising a ceiling is a reviewed one-line edit landed with the change that
  // needs it (§8).
  // ==========================================================================

  "holosphere": {
    "board": "teensy40",
    "regions": {
      // Holosphere runs RingSpin at 96x20; these ceilings retain wide FLASH and
      // RAM1 headroom. RAM2 remains close to the hardware wall.
      "flash": { "max_bytes": 1900000 },
      "ram1":  { "max_bytes": 490000, "free_min_bytes": 32768 },
      "ram2":  { "max_bytes": 524288 }                          // OCRAM is structurally full (~6 KB free); cap at the wall
    },
    "symbols": {
      "arena":         { "name": "_ZL18global_arena_block", "region": "DTCM", "min_bytes": 327680, "max_bytes": 360448 }, // 337,920 B (330 KiB)
      "framebuffer_a": { "name": "_ZN6Effect8buffer_aE",    "region": "OCRAM" },
      "framebuffer_b": { "name": "_ZN6Effect8buffer_bE",    "region": "OCRAM" }
      // NOTE: reaction_graph (ReactionGraph::neighbors) is GC'd out of Holosphere
      // — RingSpin uses no reaction-diffusion effect — so it is intentionally NOT
      // a layout symbol here. It IS checked for Phantasm (below).
    }
  },

  "phantasm": {
    "board": "teensy40",
    "regions": {
      // -Os + nano + flash routing (custom ld script), with the ITCM bank
      // reclaimed (FLASHMEM repatriation), the RNG/cos_theta DTCM trims, and the
      // arena sized down to 330 KiB from its measured worst-effect high-water:
      // RAM1 used 509,312, free-for-locals 14,976. Fits with margin above the
      // floor below. RAM2 519,552.
      "flash": { "max_bytes": 1900000 },
      // free_min_bytes is the DTCM stack reservation. The host stack-painting
      // gate (tests/stack_measure.cpp) measures a worst-effect peak of 9,055 B
      // (Dynamo); 12 KiB covers that (host figure already over-estimates the
      // 4-byte-pointer device) plus the ISR allowance. max_bytes = 524288 -
      // 12288, so the 12 KiB stack floor is the binding RAM1 constraint (was
      // 16 KiB — re-derived from the measured peak, not a round guess).
      // The ITCM code component ceiling makes growth into intra-bank padding
      // visible: RAM1 `used`/`free` don't move until a whole 32 KiB bank flips
      // (docs/selective_o3_spec.md §3/§6). Calibrated 2026-07-15 at the fused
      // scan-driver regions: code 152,984 + 2,048 headroom. Each kept HS_O3
      // region commit re-bumps to its own measured code + 2,048.
      "ram1":  { "max_bytes": 512000, "free_min_bytes": 12288,
                 "components": { "code": { "max_bytes": 155032 } } },
      // 3.5 KiB effect-object cap plus 512 B for allocator and boot overhead.
      "ram2":  { "max_bytes": 524288, "free_min_bytes": 4096 }
    },
    "symbols": {
      "arena":          { "name": "_ZL18global_arena_block",        "region": "DTCM", "min_bytes": 327680, "max_bytes": 360448 },
      "framebuffer_a":  { "name": "_ZN6Effect8buffer_aE",          "region": "OCRAM" },
      "framebuffer_b":  { "name": "_ZN6Effect8buffer_bE",          "region": "OCRAM" },
      // Phantasm instantiates all effects (incl. reaction-diffusion), so the K-NN
      // table is present and must stay in flash (const => flash/.rodata; §7.4 #3).
      // Verified on the real Phantasm ELF.
      "reaction_graph": { "name": "_ZN13ReactionGraph9neighborsE", "region": "FLASH" },
      // The segment LED controller's HD107SFrame buffers are the eDMA TX source and
      // must stay in cached, DMA-reachable OCRAM (where arm_dcache_flush() is real;
      // §5/§8). Defined as an explicit specialization in Phantasm.ino because GCC
      // drops DMAMEM on the vague-linkage template static member.
      "dma_tx_buffer":  { "name": "_ZN12POVSegmentedILi288ELi4ELi480EE14ledController_E", "region": "OCRAM" }
    }
  }
}
