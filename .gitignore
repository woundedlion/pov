# Visual Micro generated state + per-user VS project settings. Un-anchored so it
# matches under targets/ (the root-anchored /__vm/ did not), and *.vcxproj.user
# was previously tracked only because it predated these rules.
__vm/
*.vcxproj.user
.clangd

# Python bytecode cache
__pycache__/
*.pyc
