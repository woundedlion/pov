# CMake / build outputs
/build/
/build_debug/
/build_test/
*.obj
*.o
*.pdb
*.ilk
build.log

# CMake user presets (machine-local overrides)
CMakeUserPresets.json

# Dependencies / generated
/node_modules/
/.doxygen-awesome/
# Machine-local Doxygen config the justfile 'docs' recipe feeds to doxygen
# (analogous to CMakeUserPresets.json / .doxygen-awesome above).
/Doxyfile.local

# IDE / tooling
.vs/
# Local agent/tooling config (machine-specific, not repo-shared)
.claude/
.agent/
.agents/
/out/
/obj/
# Visual Studio / Visual Micro generated project and per-user state. Un-anchored
# so these rules also match projects regenerated under targets/.
__vm/
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
.clangd

# PlatformIO build tree (Teensy CI gate). Lives at the repo root because the
# gate uses src_dir = . to reach sources in core/ and targets/. VMicro never
# writes here and PlatformIO never writes into __vm/, so the two coexist.
/.pio/
# PlatformIO converts the selected sketch to <name>.ino.cpp next to the .ino
# during a build (normally deleted on exit). Ignore it so an interrupted build
# can't leave it tracked — and so VMicro never sees a stray duplicate of setup()/loop().
*.ino.cpp

# Python bytecode cache
__pycache__/
*.pyc
